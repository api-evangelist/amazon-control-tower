{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/amazon-control-tower/refs/heads/main/json-schema/baseline-operation-schema.json",
  "title": "BaselineOperation",
  "description": "An operation performed on a baseline.",
  "type": "object",
  "properties": {
    "endTime": {
      "type": "string",
      "format": "date-time"
    },
    "operationIdentifier": {
      "type": "string"
    },
    "operationType": {
      "type": "string",
      "enum": [
        "ENABLE_BASELINE",
        "DISABLE_BASELINE",
        "UPDATE_ENABLED_BASELINE",
        "RESET_ENABLED_BASELINE"
      ]
    },
    "startTime": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "SUCCEEDED",
        "FAILED",
        "IN_PROGRESS"
      ]
    },
    "statusMessage": {
      "type": "string"
    }
  }
}